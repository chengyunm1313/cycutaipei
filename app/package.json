{
	"name": "app",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build --webpack",
		"start": "next start",
		"lint": "eslint",
		"db:migrate:local": "npx wrangler d1 migrations apply product-catalog-db --local",
		"db:migrate:remote": "npx wrangler d1 migrations apply product-catalog-db --remote",
		"db:seed": "curl -X POST http://localhost:3000/api/seed",
		"pages:build": "npx @cloudflare/next-on-pages",
		"pages:preview": "npm run pages:build && npx wrangler pages dev .vercel/output/static",
		"pages:deploy": "npm run pages:build && npx wrangler pages deploy .vercel/output/static",
		"smoke:rsc": "node scripts/smoke-rsc.mjs"
	},
	"dependencies": {
		"@blocknote/core": "^0.46.2",
		"@blocknote/mantine": "^0.46.2",
		"@blocknote/react": "^0.46.2",
		"@hello-pangea/dnd": "^18.0.1",
		"@mantine/core": "^8.3.15",
		"@mantine/hooks": "^8.3.15",
		"@mantine/notifications": "^8.3.15",
		"@tinymce/tinymce-react": "^6.3.0",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"next": "16.1.6",
		"react": "19.2.3",
		"react-dom": "19.2.3"
	},
	"devDependencies": {
		"@cloudflare/next-on-pages": "^1.13.16",
		"@cloudflare/workers-types": "^4.20260219.0",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"eslint": "^9",
		"eslint-config-next": "16.1.6",
		"tailwindcss": "^4",
		"typescript": "^5",
		"wrangler": "^4.68.1"
	}
}
